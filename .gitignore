# ==============================================================================
# Flutter / Dart / Pub
# ==============================================================================
# Dart tool caches
.dart_tool/
.pub-cache/
.pub/

# Flutter generated files
.flutter-plugins
.flutter-plugins-dependencies
**/generated_plugin_registrant.dart

# Build output
build/
**/doc/api/

# Pub lockfile (keep pubspec.lock for apps, ignore for libraries)
# pubspec.lock   ← intentionally kept for reproducible builds

# Coverage & symbols
coverage/
app.*.symbols
app.*.map.json

# Misc
*.class
*.lock
!pubspec.lock
*.log
*.pyc
*.swp
.packages
.packages.generated
.pub-preload-cache/
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds
analysis_benchmark.json

# ==============================================================================
# Android
# ==============================================================================
# Gradle build cache / wrapper binaries
.gradle/
**/.gradle/
**/android/gradlew
**/android/gradlew.bat
**/android/**/gradle-wrapper.jar

# Signing secrets — NEVER commit keystores or key.properties
*.jks
*.keystore
**/android/key.properties
**/android/local.properties
**/android/captures/

# Generated Android sources
**/android/**/GeneratedPluginRegistrant.java

# Android Studio build artifacts
/android/app/debug
/android/app/profile
/android/app/release

# Kotlin incremental compilation
**/.kotlin/

